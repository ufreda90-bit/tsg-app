# Core runtime
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dispatcher_operativo?schema=public
JWT_SECRET=change-me-with-a-long-random-secret

# Auth/session
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Safety flags
ALLOW_DEMO_TOKEN=false
DEMO_API_TOKEN=
SIGN_TOKEN_TTL_HOURS=168

# Reverse proxy / CORS
TRUST_PROXY=0
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
BODY_JSON_LIMIT=5mb
BODY_URLENCODED_LIMIT=5mb

# Attachments / uploads
UPLOAD_DIR=uploads
ATTACHMENT_MAX_FILE_SIZE_MB=15
ATTACHMENT_MAX_FILES=10
ATTACHMENTS_HEALTH_SCAN_LIMIT=2000
ATTACHMENTS_CLEANUP_SCAN_LIMIT=5000
ATTACHMENTS_CLEANUP_MIN_AGE_DAYS=7
ATTACHMENT_UPLOAD_RATE_LIMIT_WINDOW_MS=900000
ATTACHMENT_UPLOAD_RATE_LIMIT_MAX=30

# Work report / email
WORK_REPORT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Web push (optional)
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Frontend feature flags
VITE_WORK_REPORT_EMAIL_ENABLED=false
VITE_ATTACHMENT_MAX_FILE_SIZE_MB=15
