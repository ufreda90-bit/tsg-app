
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DISPATCHER
  TECHNICIAN
}

enum InterventionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  NO_SHOW
}

enum CustomerType {
  PRIVATO
  AZIENDA
}

enum PreferredTimeSlot {
  MATTINA
  PRANZO
  POMERIGGIO
  SERA
  INDIFFERENTE
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
  ARCHIVED
}

enum AttachmentKind {
  AUDIO
  IMAGE
  FILE
}

model Technician {
  id            Int            @id @default(autoincrement())
  name          String
  email         String?        @unique
  phone         String?
  color         String         @default("#3b82f6") // Blue default
  skills        String         // Comma separated for simplicity
  isActive      Boolean        @default(true)
  interventions         Intervention[] @relation("PrimaryTech")
  secondaryInterventions Intervention[] @relation("SecondaryTech")
  user          User?          @relation("TechnicianUser")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String
  role          Role
  technicianId  Int?      @unique
  technician    Technician? @relation("TechnicianUser", fields: [technicianId], references: [id])
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]

  @@index([role])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Intervention {
  id           Int         @id @default(autoincrement())
  version      Int         @default(0)
  title        String
  description  String?
  address      String
  status       InterventionStatus @default(SCHEDULED)
  priority     String      @default("MEDIUM")
  startAt      DateTime?
  endAt        DateTime?
  
  // Primary technician used for calendar scheduling and conflict checks
  technicianId Int?
  technician   Technician? @relation("PrimaryTech", fields: [technicianId], references: [id])

  // Optional second technician (the team often works in pairs)
  secondaryTechnicianId Int?
  secondaryTechnician   Technician? @relation("SecondaryTech", fields: [secondaryTechnicianId], references: [id])
  
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])

  jobId        String?
  job          Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  
  customerNameSnapshot   String?
  customerEmailSnapshot  String?
  customerPhoneSnapshot  String?
  customerAddressSnapshot String?
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  media        Media[]
  workReport   WorkReport?
  attachments  InterventionAttachment[]

  @@index([status])
  @@index([technicianId])
  @@index([secondaryTechnicianId])
  @@index([startAt])
  @@index([endAt])
  @@index([jobId])
}

model Customer {
  id           String        @id @default(uuid())
  companyName  String?
  customerType CustomerType  @default(PRIVATO)
  preferredTimeSlot PreferredTimeSlot @default(INDIFFERENTE)
  name         String
  email        String?
  phone        String?
  taxCode      String?       @unique
  vatNumber    String?
  addressLine  String?
  physicalAddress String?
  intercomInfo String?
  intercomLabel String?
  city         String?
  notes        String?
  isActive     Boolean       @default(true)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  interventions Intervention[]
  sites         Site[]
}

model Site {
  id         String    @id @default(uuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?
  address    String
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  jobs       Job[]

  @@index([customerId])
}

model Job {
  id           String         @id @default(uuid())
  siteId       String
  code         String?
  title        String
  description  String?
  status       JobStatus      @default(OPEN)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  interventions Intervention[]

  @@index([siteId])
}

model WorkReport {
  id                       String       @id @default(uuid())
  reportNumber             Int          @unique
  interventionId           Int          @unique
  intervention             Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  
  actualStartAt            DateTime?
  actualEndAt              DateTime?
  clientStartAt            DateTime?    // Timestamp locale dipendente per audit offline
  clientEndAt              DateTime?    // Timestamp locale dipendente per audit offline
  actualMinutes            Int          @default(0)

  // Pause tracking (simple MVP: total minutes + optional ongoing pause)
  pausedMinutes            Int          @default(0)
  pauseStartAt             DateTime?
  
  workPerformed            String       @default("")
  extraWork                String? 
  materials                String?
  
  customerName             String?
  customerEmail            String?
  
  signatureToken           String?      @unique
  signatureRequestedAt     DateTime?
  customerSignatureDataUrl String?
  signedAt                 DateTime?
  
  emailedAt                DateTime?
  
  createdAt                DateTime     @default(now())
  version                  Int          @default(0)
  updatedAt                DateTime     @updatedAt
  attachments              WorkReportAttachment[]
}

model Media {
  id             Int          @id @default(autoincrement())
  url            String       // Base64 string or file path
  type           String       // 'image' | 'video'
  interventionId Int
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model PushSubscription {
  id            Int         @id @default(autoincrement())
  endpoint      String      @unique
  p256dh        String
  auth          String
  technicianId  Int?
  role          String      @default("TECHNICIAN") // 'ADMIN' or 'TECHNICIAN'
  
  createdAt     DateTime    @default(now())
}

model InterventionAttachment {
  id              String         @id @default(uuid())
  interventionId  Int
  intervention    Intervention   @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  kind            AttachmentKind
  mimeType        String
  originalName    String
  storedName      String
  size            Int
  createdByUserId Int?
  createdAt       DateTime       @default(now())

  @@index([interventionId])
}

model WorkReportAttachment {
  id           String         @id @default(uuid())
  workReportId String
  workReport   WorkReport     @relation(fields: [workReportId], references: [id], onDelete: Cascade)
  kind         AttachmentKind
  mimeType     String
  originalName String
  storedName   String
  size         Int
  createdAt    DateTime       @default(now())

  @@index([workReportId])
}
