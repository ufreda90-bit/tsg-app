
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DISPATCHER
  TECHNICIAN
}

enum InterventionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  NO_SHOW
}

enum CustomerType {
  PRIVATO
  AZIENDA
}

enum PreferredTimeSlot {
  MATTINA
  PRANZO
  POMERIGGIO
  SERA
  INDIFFERENTE
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
  ARCHIVED
}

enum AttachmentKind {
  AUDIO
  IMAGE
  FILE
}

model Organization {
  id          Int                     @id @default(autoincrement())
  name        String
  plan        String?
  createdAt   DateTime                @default(now())

  users                    User[]
  technicians              Technician[]
  interventions            Intervention[]
  customers                Customer[]
  sites                    Site[]
  jobs                     Job[]
  workReports              WorkReport[]
  media                    Media[]
  pushSubscriptions        PushSubscription[]
  interventionAttachments  InterventionAttachment[]
  workReportAttachments    WorkReportAttachment[]
}

model Technician {
  id            Int            @id @default(autoincrement())
  organizationId Int
  organization  Organization   @relation(fields: [organizationId], references: [id])
  name          String
  email         String?
  phone         String?
  color         String         @default("#3b82f6") // Blue default
  skills        String         // Comma separated for simplicity
  isActive      Boolean        @default(true)
  interventions         Intervention[] @relation("PrimaryTech")
  secondaryInterventions Intervention[] @relation("SecondaryTech")
  user          User?          @relation("TechnicianUser")
  pushSubscriptions PushSubscription[]

  @@unique([organizationId, id])
  @@unique([organizationId, email])
  @@index([organizationId])
}

model User {
  id            Int       @id @default(autoincrement())
  organizationId Int
  organization  Organization @relation(fields: [organizationId], references: [id])
  name          String
  username      String
  email         String?
  phone         String?   @unique
  passwordHash  String
  role          Role
  technicianId  Int?      @unique
  technician    Technician? @relation("TechnicianUser", fields: [organizationId, technicianId], references: [organizationId, id], onDelete: Restrict)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  roleAssignments UserRoleAssignment[]

  @@unique([organizationId, username])
  @@unique([organizationId, email])
  @@unique([organizationId, technicianId])
  @@index([role])
  @@index([organizationId])
}

model UserRoleAssignment {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  organizationId Int?
  userId         Int?
  action         String
  entity         String?
  entityId       String?
  status         String?
  metadata       Json?
  ip             String?
  requestId      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Intervention {
  id           Int         @id @default(autoincrement())
  organizationId Int
  organization Organization @relation(fields: [organizationId], references: [id])
  version      Int         @default(0)
  title        String
  description  String?
  address      String
  status       InterventionStatus @default(SCHEDULED)
  priority     String      @default("MEDIUM")
  startAt      DateTime?
  endAt        DateTime?
  
  // Primary technician used for calendar scheduling and conflict checks
  technicianId Int?
  technician   Technician? @relation("PrimaryTech", fields: [organizationId, technicianId], references: [organizationId, id], onDelete: Restrict)

  // Optional second technician (the team often works in pairs)
  secondaryTechnicianId Int?
  secondaryTechnician   Technician? @relation("SecondaryTech", fields: [organizationId, secondaryTechnicianId], references: [organizationId, id], onDelete: Restrict)
  
  customerId   String?
  customer     Customer?   @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Restrict)

  jobId        String?
  job          Job?        @relation(fields: [organizationId, jobId], references: [organizationId, id], onDelete: Restrict)
  
  customerNameSnapshot   String?
  customerEmailSnapshot  String?
  customerPhoneSnapshot  String?
  customerAddressSnapshot String?
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  media        Media[]
  workReport   WorkReport?
  attachments  InterventionAttachment[]

  @@unique([organizationId, id])
  @@index([status])
  @@index([technicianId])
  @@index([secondaryTechnicianId])
  @@index([startAt])
  @@index([endAt])
  @@index([jobId])
  @@index([organizationId])
}

model Customer {
  id           String        @id @default(uuid())
  organizationId Int
  organization Organization  @relation(fields: [organizationId], references: [id])
  companyName  String?
  customerType CustomerType  @default(PRIVATO)
  preferredTimeSlot PreferredTimeSlot @default(INDIFFERENTE)
  name         String
  email        String?
  phone1       String?
  phone2       String?
  taxCode      String?
  vatNumber    String?
  addressLine  String?
  physicalAddress String?
  intercomInfo String?
  intercomLabel String?
  city         String?
  notes        String?
  isActive     Boolean       @default(true)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  interventions Intervention[]
  sites         Site[]

  @@unique([organizationId, id])
  @@unique([organizationId, taxCode])
  @@index([organizationId])
}

model Site {
  id         String    @id @default(uuid())
  organizationId Int
  organization Organization @relation(fields: [organizationId], references: [id])
  customerId String
  customer   Customer  @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Cascade)
  label      String?
  address    String
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  jobs       Job[]

  @@unique([organizationId, id])
  @@index([customerId])
  @@index([organizationId])
}

model Job {
  id           String         @id @default(uuid())
  organizationId Int
  organization Organization   @relation(fields: [organizationId], references: [id])
  siteId       String
  code         String?
  title        String
  description  String?
  status       JobStatus      @default(OPEN)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  site          Site           @relation(fields: [organizationId, siteId], references: [organizationId, id], onDelete: Cascade)
  interventions Intervention[]

  @@unique([organizationId, id])
  @@index([siteId])
  @@index([organizationId])
}

model WorkReport {
  id                       String       @id @default(uuid())
  organizationId           Int
  organization             Organization @relation(fields: [organizationId], references: [id])
  reportNumber             Int
  interventionId           Int
  intervention             Intervention @relation(fields: [organizationId, interventionId], references: [organizationId, id], onDelete: Cascade)
  
  actualStartAt            DateTime?
  actualEndAt              DateTime?
  clientStartAt            DateTime?    // Timestamp locale dipendente per audit offline
  clientEndAt              DateTime?    // Timestamp locale dipendente per audit offline
  actualMinutes            Int          @default(0)

  // Pause tracking (simple MVP: total minutes + optional ongoing pause)
  pausedMinutes            Int          @default(0)
  pauseStartAt             DateTime?
  
  workPerformed            String       @default("")
  extraWork                String? 
  materials                String?
  
  customerName             String?
  customerEmail            String?
  
  signatureToken           String?      @unique
  signatureRequestedAt     DateTime?
  customerSignatureDataUrl String?
  signedAt                 DateTime?
  
  emailedAt                DateTime?
  
  createdAt                DateTime     @default(now())
  version                  Int          @default(0)
  updatedAt                DateTime     @updatedAt
  attachments              WorkReportAttachment[]

  @@unique([organizationId, id])
  @@unique([organizationId, reportNumber])
  @@unique([organizationId, interventionId])
  @@index([organizationId])
}

model Media {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  url            String       // Base64 string or file path
  type           String       // 'image' | 'video'
  interventionId Int
  intervention   Intervention @relation(fields: [organizationId, interventionId], references: [organizationId, id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, interventionId])
  @@index([organizationId])
}

model PushSubscription {
  id            Int         @id @default(autoincrement())
  organizationId Int
  organization  Organization @relation(fields: [organizationId], references: [id])
  endpoint      String
  p256dh        String
  auth          String
  technicianId  Int?
  technician    Technician? @relation(fields: [organizationId, technicianId], references: [organizationId, id], onDelete: Restrict)
  role          String      @default("TECHNICIAN") // 'ADMIN' or 'TECHNICIAN'
  
  createdAt     DateTime    @default(now())

  @@unique([organizationId, endpoint])
  @@index([organizationId, technicianId])
  @@index([organizationId])
}

model InterventionAttachment {
  id              String         @id @default(uuid())
  organizationId  Int
  organization    Organization   @relation(fields: [organizationId], references: [id])
  interventionId  Int
  intervention    Intervention   @relation(fields: [organizationId, interventionId], references: [organizationId, id], onDelete: Cascade)
  kind            AttachmentKind
  mimeType        String
  originalName    String
  storedName      String
  size            Int
  createdByUserId Int?
  createdAt       DateTime       @default(now())

  @@index([organizationId, interventionId])
  @@index([interventionId])
  @@index([organizationId])
}

model WorkReportAttachment {
  id           String         @id @default(uuid())
  organizationId Int
  organization Organization   @relation(fields: [organizationId], references: [id])
  workReportId String
  workReport   WorkReport     @relation(fields: [organizationId, workReportId], references: [organizationId, id], onDelete: Cascade)
  kind         AttachmentKind
  mimeType     String
  originalName String
  storedName   String
  size         Int
  createdAt    DateTime       @default(now())

  @@index([organizationId, workReportId])
  @@index([workReportId])
  @@index([organizationId])
}
